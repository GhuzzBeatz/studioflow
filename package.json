{
  "name": "studioflow",
  "version": "1.0.4",
  "description": "Sistema de Gestao StudioFlow",
  "main": "main.js",
  "author": "GHZ Plugin",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.ghzplugin.studioflow",
    "productName": "StudioFlow",
    "directories": {
      "output": "dist_installer"
    },
    "files": [
      "**/*",
      "!dist_installer/**",
      "!node_modules/.cache/**"
    ],
    "extraResources": [
      {
        "from": "data/",
        "to": "data/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StudioFlow",
      "installerHeaderIcon": "logo.png",
      "deleteAppDataOnUninstall": false
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
